    "bdi_name": "Concentration Difficulty",
    "majority": 1,
    "consensus": 0,
    "type": "disagreement",
    "source": "erisk2023"
  },
  {
    "symptom_id": 10,
    "docid": "s_2067_446_2",
    "text": "It breaks my concentration when I am busy and drifts my mind away to thoughts of you when I am in the middle of conversation.",
