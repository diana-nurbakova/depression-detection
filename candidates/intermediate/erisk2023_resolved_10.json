    "bdi_name": "Concentration Difficulty",
    "majority": 1,
    "consensus": 0,
    "type": "disagreement",
    "source": "erisk2023"
  },
  {
    "symptom_id": 10,
    "docid": "s_2007_829_1",
    "text": "School wasted all my energy now I can't focus",
