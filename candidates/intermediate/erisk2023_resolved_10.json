  },
  {
    "symptom_id": 10,
    "docid": "s_1692_706_6",
    "text": "My mind races and I cant focus on anything but the minutes ticking by.",
    "bdi_query": 19,
    "bdi_name": "Concentration Difficulty",
    "majority": 1,
    "consensus": 0,
    "type": "disagreement",
    "source": "erisk2023"
  },
  {
    "symptom_id": 10,
    "docid": "s_1846_49_12",
    "text": "My worrying over this has also caused me to lose some much needed focus on my tasks.",
